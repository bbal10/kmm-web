# Production Environment Variables
# Copy this file to .env.production and set the actual values

# Django Core Settings
DJANGO_ENV=production
SECRET_KEY=your-very-secure-secret-key-here-minimum-50-characters-long
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/kmm_web_db

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://localhost:6379/1

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@kmm-mesir.org

# Cloudflare R2 Storage (S3-compatible) — untuk media & static files
# Set USE_R2=True untuk mengaktifkan. Jika False/kredensial tidak lengkap,
# media pakai filesystem lokal & static pakai Whitenoise.
USE_R2=False
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# Cloudflare account ID (dipakai untuk endpoint default), ATAU set R2_ENDPOINT_URL penuh
R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Domain publik (opsional) untuk serve file tanpa presigned URL, mis. cdn.kmm-mesir.org
R2_CUSTOM_DOMAIN=
# Prefix folder di bucket (opsional)
R2_MEDIA_LOCATION=media
R2_STATIC_LOCATION=static

# Admin Configuration
ADMIN_EMAIL=admin@kmm-mesir.org

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-url
ENVIRONMENT=production

# Server Configuration
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
