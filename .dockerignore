# Docker environment file (contains secrets)
.env
.env.*
!.env.example
!.env.*.example

# Python virtual environment (rebuilt inside image via uv sync)
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Node / frontend (rebuilt inside image via npm ci)
node_modules/
**/node_modules/
.next/

# Collected static (regenerated by collectstatic in entrypoint)
staticfiles/

# Version control & tooling
.git/
.gitignore
.github/

# SSL certificates (should be managed separately)
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt

# Database & backups (should be backed up separately)
db.sqlite3
db.sqlite3-journal
backups/*.sql
backups/*.sql.gz
backups/*.tar.gz

# User uploaded media files (should be backed up separately)
media/*

# Application logs
logs/*.log

# Editor / OS cruft
.vscode/
.idea/
*.iml
.DS_Store
