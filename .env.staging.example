# Staging Environment Variables
# Copy this file to .env.staging and set the actual values
# Usage: DJANGO_ENV=staging python manage.py runserver

# ============================================================================
# Django Core Settings
# ============================================================================
DJANGO_ENV=staging

# Secret key (minimal 50 karakter)
SECRET_KEY=your-staging-secret-key-here-minimum-50-characters-long

# Debug mode (True untuk staging agar mudah debugging)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,staging.yourdomain.com

# ============================================================================
# Database Configuration (PostgreSQL - sama seperti production)
# ============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/kmm_web_staging

# ============================================================================
# Redis Configuration (optional, untuk cache)
# ============================================================================
REDIS_URL=redis://localhost:6379/1

# ============================================================================
# Email Configuration
# ============================================================================
# Console backend (default untuk staging - print ke terminal)
# Uncomment jika ingin pakai SMTP:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

DEFAULT_FROM_EMAIL=noreply@staging.kmm-mesir.org

# ============================================================================
# Admin Configuration
# ============================================================================
ADMIN_EMAIL=admin@staging.kmm-mesir.org

# ============================================================================
# Monitoring (optional)
# ============================================================================
# SENTRY_DSN=your-staging-sentry-dsn
# ENVIRONMENT=staging

# ============================================================================
# AWS S3 Configuration (optional - untuk file storage)
# ============================================================================
USE_S3=False
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-staging-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-staging-cdn-domain.com
